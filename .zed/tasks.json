[
  {
    "label": "utils: Git Clone all repositories",
    "command": "uv",
    "args": [
      "run",
      "git-clone-all-repos"
    ],
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Upload addon to server and restart",
    "command": "uv",
    "args": [
      "run",
      "upload-to-addon-folder",
      "-f",
      "$ZED_RELATIVE_FILE",
      "--debug"
    ],
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "utils: Update AYON server",
    "command": "uv",
    "args": [
      "run",
      "update-ayon-docker-local-dir"
    ],
    "use_new_terminal": true,
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "utils: Initialize Docs",
    "command": "uv",
    "args": [
      "run",
      "docs-initialize"
    ],
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "utils: Start Docs",
    "command": "uv",
    "args": [
      "run",
      "docs-start"
    ],
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "utils: Git commit info extraction",
    "command": "uv",
    "args": [
      "run",
      "git-commit-info-extraction",
      "-f",
      "$ZED_RELATIVE_FILE"
    ],
    "reveal": "always",
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "hide": "never"
  },
  {
    "label": "Ruff check current file",
    "command": "uv",
    "args": [
      "run",
      "ruff",
      "check",
      "$ZED_RELATIVE_FILE"
    ],
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "AYON - Launch App (Compositing)",
    "command": "uv",
    "args": [
      "run",
      "ayon-launch-app",
      "--project", "AY01_VFX_demo",
      "--folder", "shots/sq001/sh010",
      "--task", "comp"
    ],
    "use_new_terminal": true,
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "AYON - Launch App (Editorial)",
    "command": "uv",
    "args": [
      "run",
      "ayon-launch-app",
      "--project", "AY01_VFX_demo",
      "--folder", "editorial",
      "--task", "conform"
    ],
    "use_new_terminal": true,
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Launcher Dev Mode",
    "command": "uv",
    "args": [
      "run",
      "launcher-dev-mode",
    ],
    "use_new_terminal": true,
    "reveal": "always",
    "hide": "on_success"
  }
]
